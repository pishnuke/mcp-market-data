{
  "mcpServers": {
    "market-data-http": {
      "transport": {"type": "http", "url": "http://127.0.0.1:8000"}
    },
    "market-data-local": {
      "command": "uvicorn",
      "args": ["app.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "env": {
        "DATA_DIR": "./data",
        "LAMA_UI_SERVICE_URL": "http://127.0.0.1:8502"
      }
    }
  }
}
